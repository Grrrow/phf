---
import type { LocaleCode } from '../../i18n/config';
import { getAbsoluteAssetUrl } from '../../utils/urls';

export interface Props {
  locale: LocaleCode;
  currentPath?: string;
  globalConfig?: any;
  alternates?: { href: string; hreflang: string }[];
}

const { locale, currentPath = '/', globalConfig } = Astro.props;
const footerConfig = globalConfig?.footer?.[0] || {};
const footerLogoUrl = getAbsoluteAssetUrl(footerConfig?.footer_logo?.filename);
const footerLogoAlt = footerConfig?.footer_logo_alt || 'Pedro Halffter';
const brandText = footerConfig?.brand_text || 'PEDRO HALFFTER';
const legalLinks = footerConfig?.legal_links || [];
const copyrightText = footerConfig?.copyright_text || `© ${new Date().getFullYear()} PEDRO HALFFTER. ALL RIGHTS RESERVED.`;
---
<footer class="global-footer-wrapper reveal-footer">
  <div class="footer-card">
    <div class="footer-content-container">
      <div class="footer-brand">
        {footerLogoUrl ? (
          <img src={footerLogoUrl} alt={footerLogoAlt} />
        ) : (
          <span class="brand-text">{brandText}</span>
        )}
      </div>
      
      <nav class="footer-nav" aria-label="Footer Navigation">
        <ul>
          {legalLinks.map((item: any) => {
            let linkHref = '#';
            if (item.link?.cached_url) {
              if (item.link.cached_url.startsWith('http')) {
                linkHref = item.link.cached_url;
              } else {
                const cleaned = item.link.cached_url.split('/').filter(Boolean).join('/');
                linkHref = cleaned ? `/${cleaned}/` : '/';
              }
            }
            return (
              <li>
                <a href={linkHref}>{item.label}</a>
              </li>
            );
          })}
        </ul>
      </nav>
      
      <div class="footer-copyright">
        <span>{copyrightText.toUpperCase()}</span>
      </div>
    </div>
  </div>
</footer>

<script>
  function initFooterObserver() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    const footer = document.querySelector('.reveal-footer');
    if (footer) observer.observe(footer);
  }

  initFooterObserver();
  document.addEventListener('astro:page-load', initFooterObserver);
</script>

<style>
  .global-footer-wrapper {
    background-color: #ffffff;
    border-top: 1px solid #f5f5f5;
    padding: 0;
    width: 100%;
    margin-top: 5rem;
  }
  
  /* Reveal Animation */
  .reveal-footer {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: opacity, transform;
  }

  .reveal-footer.revealed {
    opacity: 1;
    transform: translateY(0);
  }
  
  .footer-card {
    background-color: #ffffff;
    width: 100%;
    padding: 4rem 0;
    display: flex;
    justify-content: center;
  }

  .footer-content-container {
    max-width: 1440px;
    width: 100%;
    padding: 0 4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }
  
  /* Left column: Brand text */
  .footer-brand .brand-text {
    font-size: 1rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: #1a1a1a;
  }
  
  .footer-brand img {
    height: 35px;
    width: auto;
    display: block;
  }
  
  /* Center column: Nav links */
  .footer-nav ul {
    list-style: none;
    display: flex;
    gap: 2.25rem;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
    justify-content: center;
  }
  
  .footer-nav a {
    font-size: 0.7rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    text-decoration: none;
    color: #8e9aa8; /* gris azulado suave */
    transition: color 0.3s ease;
  }
  
  .footer-nav a:hover,
  .footer-nav a:focus {
    color: #1a1a1a;
  }
  
  /* Right column: Copyright */
  .footer-copyright {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #1a1a1a; /* negro con mayor peso */
    text-align: right;
  }
  
  /* Mobile styling */
  @media (max-width: 900px) {
    .footer-card {
      padding: 3rem 0;
    }
    
    .footer-content-container {
      flex-direction: column;
      text-align: center;
      padding: 0 2rem;
      gap: 2.25rem;
    }
    
    .footer-nav ul {
      flex-direction: column;
      gap: 1.25rem;
      align-items: center;
    }
    
    .footer-copyright {
      text-align: center;
    }
  }
</style>
