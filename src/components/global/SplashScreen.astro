<div id="global-splash-screen" class="splash-screen">
  <div class="splash-content">
    <img src="/favico.png" alt="Pedro Halffter Logo" class="splash-icon" />
  </div>
</div>

<script>
  function initSplashScreen() {
    const splash = document.getElementById('global-splash-screen');
    const content = splash?.querySelector('.splash-content') as HTMLElement;
    if (!splash || !content) return;

    // Solo mostrar el splash en la portada (Home)
    const isHome = window.location.pathname === '/' || window.location.pathname === '/es/' || window.location.pathname === '/es';
    
    // Y solo mostrarlo una vez por sesión (para no cansar al usuario si recarga)
    // TEMPORALMENTE DESACTIVADO para que puedas probarlo fácilmente recargando la página
    // const hasSeenSplash = sessionStorage.getItem('phlf_splash_seen');
    const hasSeenSplash = false; 
    
    if (!isHome || hasSeenSplash) {
      splash.style.display = 'none';
      return;
    }

    // sessionStorage.setItem('phlf_splash_seen', 'true');
    document.body.style.overflow = 'hidden';

    // Fase 1: Palpitar (se hace por CSS con la clase inicial)
    
    // Fase 2: Abrirse hacia el contenido
    setTimeout(() => {
      // Le añadimos la clase que hace el zoom extremo y el fundido
      splash.classList.add('splash-reveal');
      content.classList.add('icon-zoom');
      
      // Restauramos el scroll
      document.body.style.overflow = '';
      
      // Destruimos el splash después de la animación
      setTimeout(() => {
        splash.style.display = 'none';
      }, 700); 
    }, 800); // Está solo 0.8s palpitando antes de abrirse
  }

  initSplashScreen();
</script>

<style>
  .splash-screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: #ffffff;
    z-index: 99999;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: opacity 0.6s cubic-bezier(0.85, 0, 0.15, 1), visibility 0.6s;
  }

  .splash-content {
    /* Animación de palpitar inicial */
    animation: pulse 1s infinite alternate ease-in-out;
    transform-origin: center center;
    will-change: transform, opacity;
  }

  .splash-icon {
    width: 120px;
    height: 120px;
    object-fit: contain;
  }

  /* Animaciones */
  @keyframes pulse {
    0% { transform: scale(0.95); opacity: 0.8; }
    100% { transform: scale(1.05); opacity: 1; }
  }

  /* Clases inyectadas por JS para el final */
  .splash-screen.splash-reveal {
    opacity: 0;
    visibility: hidden;
  }

  .splash-content.icon-zoom {
    animation: none; /* Quitamos el palpitar */
    transform: scale(40) rotate(720deg); /* Huracán: zoom extremo rotando a gran velocidad */
    opacity: 0; /* Se desvanece mientras hace zoom */
    transition: transform 0.9s cubic-bezier(0.85, 0, 0.15, 1), opacity 0.6s ease-in;
  }
</style>
