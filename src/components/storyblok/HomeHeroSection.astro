---
import { storyblokEditable } from '@storyblok/astro';
import StoryblokImage from '../media/StoryblokImage.astro';

const { blok } = Astro.props;

// Helper to determine if we should show the CTA
const hasCta = blok.cta_text && blok.cta_link?.cached_url;
const ctaHref = blok.cta_link?.cached_url ? (blok.cta_link.cached_url.startsWith('http') ? blok.cta_link.cached_url : `/${blok.cta_link.cached_url.replace(/^\/|\/$/g, '')}/`) : '#';
---

<section {...storyblokEditable(blok)} class="home-hero-section">
  <div class="hero-container">
    
    <div class="hero-content">
      {blok.eyebrow && <span class="hero-eyebrow">{blok.eyebrow}</span>}
      {blok.title && <h1 class="hero-title">{blok.title}</h1>}
      {blok.description && <p class="hero-description">{blok.description}</p>}
      
      {hasCta && (
        <a href={ctaHref} class="hero-cta">
          {blok.cta_text}
          <svg class="hero-cta-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      )}
    </div>

    <div class="hero-image-wrapper">
      {blok.image?.filename && (
        <div class="hero-image-inner">
          <StoryblokImage
            image={blok.image}
            alt={blok.image_alt || blok.title || 'Pedro Halffter'}
            width={1200}
            height={1600}
            widths={[480, 768, 1024, 1440]}
            sizes="(min-width: 1024px) 50vw, 100vw"
            isLcp={true}
            crop="smart"
            class="hero-img"
          />
        </div>
      )}
    </div>

  </div>
</section>

<style>
  .home-hero-section {
    background-color: var(--surface-bright); /* Fondo gris muy claro / blanco roto */
    width: 100%;
    padding-top: 2rem; /* Menos aire arriba para que quede más integrado con la cabecera */
    padding-bottom: var(--section-stack);
    overflow: hidden;
  }

  .hero-container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--margin-x);
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 600px;
  }

  .hero-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent-slate);
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 5vw, 4.5rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--primary);
    margin-bottom: 2.5rem;
    letter-spacing: -0.02em;
  }

  .hero-description {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--on-surface-variant);
    margin-bottom: 3rem;
    max-width: 480px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--primary);
    text-decoration: none;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-light);
    transition: all 0.3s ease;
  }

  .hero-cta:hover {
    color: var(--accent-gold);
    border-bottom-color: var(--accent-gold);
  }

  .hero-cta-icon {
    transition: transform 0.3s ease;
  }

  .hero-cta:hover .hero-cta-icon {
    transform: translateX(5px);
  }

  .hero-image-wrapper {
    width: 100%;
    position: relative;
  }

  .hero-image-inner {
    position: relative;
    width: 100%;
    /* Reservar espacio para evitar CLS (aspect ratio 3:4 aprox) */
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  /* Usamos un selector :global porque la imagen viene renderizada por StoryblokImage */
  .hero-image-inner :global(img.hero-img) {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%); /* Imagen en blanco y negro por defecto */
    transition: filter 0.5s ease;
  }

  @media (hover: hover) {
    .hero-image-inner:hover :global(img.hero-img) {
      filter: grayscale(0%);
    }
  }

  @media (max-width: 1023px) {
    .hero-image-inner :global(img.hero-img) {
      filter: grayscale(0%); /* A todo color siempre en móvil, ya que no hay hover real */
    }
  }

  @media (min-width: 1024px) {
    .hero-container {
      grid-template-columns: 4fr 6fr; /* Desktop: texto menos ancho que la imagen */
      gap: 6rem;
    }

    .home-hero-section {
      padding-top: 3rem; /* Ajustado el aire en escritorio */
      padding-bottom: calc(var(--section-stack) * 1.5);
    }
  }

  @media (max-width: 1023px) {
    .home-hero-section {
      padding-bottom: 0; /* Quitar el aire excesivo abajo en móvil */
    }

    .hero-content {
      order: 2; /* Mobile: texto abajo */
    }
    .hero-image-wrapper {
      order: 1; /* Mobile: imagen arriba primero */
      /* Full bleed en móvil para impactar más */
      margin-left: calc(var(--margin-x) * -1);
      margin-right: calc(var(--margin-x) * -1);
      width: calc(100% + calc(var(--margin-x) * 2));
    }
    
    .hero-container {
      gap: 3rem; /* Menos aire entre imagen y texto en móvil */
    }
    
    .hero-title {
      font-size: 2.5rem;
    }
  }

  /* Animaciones de entrada (Fade Up) para carga inicial */
  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-eyebrow,
  .hero-title,
  .hero-description,
  .hero-cta {
    opacity: 0;
    animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    will-change: opacity, transform;
  }

  .hero-image-wrapper {
    opacity: 0;
    animation: heroFadeUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.2s;
    will-change: opacity, transform;
  }

  .hero-eyebrow { animation-delay: 0.1s; }
  .hero-title { animation-delay: 0.2s; }
  .hero-description { animation-delay: 0.3s; }
  .hero-cta { animation-delay: 0.4s; }
</style>
