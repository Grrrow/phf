---
import { storyblokEditable } from '@storyblok/astro';
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';

const { blok } = Astro.props;

// Helper for CTA
const hasCta = blok.cta_label && blok.cta_link?.cached_url;
const ctaHref = blok.cta_link?.cached_url ? (blok.cta_link.cached_url.startsWith('http') ? blok.cta_link.cached_url : `/${blok.cta_link.cached_url.replace(/^\/|\/$/g, '')}/`) : '#';

const themeClass = blok.theme === 'dark' ? 'theme-dark' : 'theme-light';
const layoutClass = `layout-${blok.layout_variant || 'editorial_grid'}`;
---

<section {...storyblokEditable(blok)} class={`featured-works-section ${themeClass} ${layoutClass}`}>
  <div class="works-container">
    
    <header class="works-header">
      {blok.eyebrow && <span class="header-eyebrow">{blok.eyebrow}</span>}
      {blok.title && <h2 class="header-title">{blok.title}</h2>}
      {blok.show_decorative_line && <div class="decorative-line" aria-hidden="true"></div>}
      {blok.subtitle && <p class="header-subtitle">{blok.subtitle}</p>}
    </header>

    {blok.items && blok.items.length > 0 && (
      <div class="works-grid">
        {blok.items.map((itemBlok: any) => (
          <StoryblokComponent blok={itemBlok} />
        ))}
      </div>
    )}

    {hasCta && (
      <div class="works-footer">
        <a href={ctaHref} class="section-cta">
          {blok.cta_label}
        </a>
      </div>
    )}
  </div>
</section>

<style>
  .featured-works-section {
    width: 100%;
    padding: var(--section-stack, 6rem) 0;
    background-color: var(--surface-bright, #FAFAFA);
  }

  .featured-works-section.theme-dark {
    background-color: var(--primary, #111);
    color: var(--surface-bright, #FAFAFA);
  }

  .works-container {
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    padding: 0 var(--margin-x, 1.5rem);
  }

  .works-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 800px;
    margin: 0 auto 4rem auto;
  }

  .header-eyebrow {
    font-family: var(--font-sans, sans-serif);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent-slate, #666);
    margin-bottom: 1rem;
  }

  .theme-dark .header-eyebrow {
    color: var(--on-primary-variant, #AAA);
  }

  .header-title {
    font-family: var(--font-serif, serif);
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 400;
    line-height: 1.1;
    color: inherit;
    margin: 0 0 1.5rem 0;
    letter-spacing: -0.02em;
  }

  .decorative-line {
    width: 60px;
    height: 1px;
    background-color: var(--accent-gold, #CBA052);
    margin: 0 auto 1.5rem auto;
  }

  .header-subtitle {
    font-family: var(--font-serif, serif);
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--on-surface-variant, #444);
    margin: 0;
  }

  .theme-dark .header-subtitle {
    color: var(--on-primary-variant, #CCC);
  }

  /* Base Grid Setup */
  .works-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  /* Desktop Grid Configuration */
  @media (min-width: 768px) {
    .works-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
    
    .layout-editorial_grid .works-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Masonry fallback using CSS columns if requested */
  .layout-masonry .works-grid {
    display: block;
    column-count: 1;
    column-gap: 2rem;
  }

  @media (min-width: 768px) {
    .layout-masonry .works-grid {
      column-count: 2;
    }
  }

  @media (min-width: 1024px) {
    .layout-masonry .works-grid {
      column-count: 3;
    }
  }

  .works-footer {
    display: flex;
    justify-content: center;
    margin-top: 4rem;
  }

  .section-cta {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-sans, sans-serif);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--primary, #111);
    text-decoration: none;
    padding: 1rem 2rem;
    border: 1px solid var(--border-light, #E5E5E5);
    transition: all 0.3s ease;
  }

  .theme-dark .section-cta {
    color: var(--surface-bright, #FAFAFA);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .section-cta:hover {
    background-color: var(--primary, #111);
    color: var(--surface-bright, #FAFAFA);
    border-color: var(--primary, #111);
  }

  .theme-dark .section-cta:hover {
    background-color: var(--surface-bright, #FAFAFA);
    color: var(--primary, #111);
    border-color: var(--surface-bright, #FAFAFA);
  }
</style>
