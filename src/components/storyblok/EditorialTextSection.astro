---
import { storyblokEditable, renderRichText } from '@storyblok/astro';

const { blok } = Astro.props;
const renderedText = blok.text ? renderRichText(blok.text) : '';

// Logic variables
const widthVariant = blok.text_width || 'medium';
const alignVariant = blok.alignment || 'left';
const headingLevel = blok.heading_level || 'h2';
const spaceTop = blok.spacing_top || 'small';
const spaceBottom = blok.spacing_bottom || 'large';

const TitleTag = headingLevel as any;

let widthClass = 'width-medium';
if (widthVariant === 'narrow') widthClass = 'width-narrow';
else if (widthVariant === 'wide') widthClass = 'width-wide';

const alignClass = `align-${alignVariant}`;
---

<section 
  {...storyblokEditable(blok)} 
  class={`editorial-text-section pt-${spaceTop} pb-${spaceBottom}`}
>
  <div class={`container ${widthClass} ${alignClass}`}>
    
    <div class="text-header">
      {blok.eyebrow && <span class="eyebrow">{blok.eyebrow}</span>}
      {blok.title && <TitleTag class="title">{blok.title}</TitleTag>}
    </div>

    {blok.text && (
      <div class="richtext-wrapper" set:html={renderedText}></div>
    )}

  </div>
</section>

<style>
  .editorial-text-section {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .container {
    width: 100%;
    padding: 0 var(--margin-x, 1.5rem);
    margin: 0 auto;
  }

  /* Max Widths for Reading */
  .width-narrow { max-width: 650px; }
  .width-medium { max-width: 800px; }
  .width-wide { max-width: 1024px; }

  /* Alignments */
  .align-left { text-align: left; }
  .align-center { text-align: center; }

  /* Title spacing for center alignment */
  .align-center .text-header {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .text-header {
    margin-bottom: 2rem;
  }

  .eyebrow {
    font-family: var(--font-sans, sans-serif);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-gold, #CBA052);
    margin-bottom: 0.75rem;
    display: block;
  }

  .title {
    font-family: var(--font-serif, serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    line-height: 1.2;
    margin: 0;
    color: inherit;
  }

  .richtext-wrapper {
    font-family: var(--font-sans, sans-serif);
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--on-surface-variant, #444);
  }

  :global(.theme-dark) .richtext-wrapper {
    color: var(--on-primary-variant, #CCC);
  }

  .richtext-wrapper :global(p) {
    margin-bottom: 1.5rem;
  }

  .richtext-wrapper :global(p:last-child) {
    margin-bottom: 0;
  }

  /* Vertical Spacing Utility Classes */
  .pt-none { padding-top: 0; }
  .pt-small { padding-top: 3rem; }
  .pt-medium { padding-top: 6rem; }
  .pt-large { padding-top: 9rem; }

  .pb-none { padding-bottom: 0; }
  .pb-small { padding-bottom: 3rem; }
  .pb-medium { padding-bottom: 6rem; }
  .pb-large { padding-bottom: 9rem; }
</style>
