---
import { storyblokEditable } from '@storyblok/astro';

const { blok } = Astro.props;

const hasLink = blok.cta_link?.cached_url;
const linkUrl = hasLink ? (blok.cta_link.cached_url.startsWith('http') ? blok.cta_link.cached_url : `/${blok.cta_link.cached_url.replace(/^\/|\/$/g, '')}/`) : null;
const linkTarget = blok.open_in_new_tab ? '_blank' : '_self';
const linkRel = blok.open_in_new_tab ? 'noopener noreferrer' : undefined;
const defaultAria = blok.media_type === 'audio' ? `Listen now: ${blok.title}` : `Explore work: ${blok.title}`;

const sizeClass = `size-${blok.card_size || 'medium'}`;
const styleClass = `style-${blok.card_style || 'media_feature'}`;
const mediaType = blok.media_type || 'none';
const hasMedia = mediaType !== 'none' && blok.image?.filename;

// Image Optimization Helper using Storyblok Image Service
function getOptimizedImageUrl(url: string, width: number, quality: number) {
  if (!url) return '';
  return `${url}/m/${width}x0/filters:quality(${quality})`;
}

let srcSet = '';
let sizes = '';
let defaultSrc = '';

if (hasMedia) {
  const isLarge = blok.card_size === 'large';
  const imgUrl = blok.image.filename;
  
  if (isLarge) {
    srcSet = `${getOptimizedImageUrl(imgUrl, 768, 80)} 768w, ${getOptimizedImageUrl(imgUrl, 1024, 80)} 1024w, ${getOptimizedImageUrl(imgUrl, 1440, 80)} 1440w`;
    sizes = '(min-width: 1024px) 60vw, 100vw';
    defaultSrc = getOptimizedImageUrl(imgUrl, 1024, 80);
  } else {
    srcSet = `${getOptimizedImageUrl(imgUrl, 320, 75)} 320w, ${getOptimizedImageUrl(imgUrl, 480, 75)} 480w, ${getOptimizedImageUrl(imgUrl, 640, 75)} 640w, ${getOptimizedImageUrl(imgUrl, 800, 75)} 800w`;
    sizes = '(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw';
    defaultSrc = getOptimizedImageUrl(imgUrl, 640, 75);
  }
}

const showPlayIcon = mediaType === 'audio' || mediaType === 'video';
const altText = blok.image_is_decorative ? "" : (blok.image_alt || blok.title || "Featured work image");

// Determine the inner content wrapper
const CardWrapper = hasLink ? 'a' : 'div';
const wrapperProps = hasLink ? {
  href: linkUrl,
  target: linkTarget,
  rel: linkRel,
  'aria-label': defaultAria,
  class: 'card-inner-wrapper'
} : {
  class: 'card-inner-wrapper'
};
---

<article {...storyblokEditable(blok)} class={`work-highlight-card ${sizeClass} ${styleClass}`}>
  <CardWrapper {...wrapperProps}>
    
    {hasMedia && (
      <div class="card-media">
        <img 
          src={defaultSrc} 
          srcset={srcSet}
          sizes={sizes}
          alt={altText}
          loading="lazy"
          class="media-image"
        />
        
        {showPlayIcon && (
          <div class="media-overlay">
            <div class="play-icon" aria-hidden="true">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="12" cy="12" r="11" stroke="currentColor" stroke-width="1.5" fill="rgba(0,0,0,0.3)"/>
                <path d="M10 8L16 12L10 16V8Z" fill="currentColor"/>
              </svg>
            </div>
            {blok.duration_label && (
              <span class="duration-badge">{blok.duration_label}</span>
            )}
          </div>
        )}
      </div>
    )}

    <div class="card-content">
      <div class="content-header">
        {blok.category && <span class="card-category">{blok.category}</span>}
        {blok.duration_label && !hasMedia && <span class="card-duration">{blok.duration_label}</span>}
      </div>
      
      {blok.title && <h3 class="card-title">{blok.title}</h3>}
      {blok.description && <p class="card-description">{blok.description}</p>}
      
      {blok.cta_label && (
        <div class="card-footer">
          <span class="card-cta">{blok.cta_label}</span>
        </div>
      )}
    </div>

  </CardWrapper>
</article>

<style>
  .work-highlight-card {
    display: flex;
    flex-direction: column;
    background-color: var(--surface-bright, #FAFAFA);
    border: 1px solid var(--border-light, #E5E5E5);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    height: 100%;
  }

  .work-highlight-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.05);
  }

  .card-inner-wrapper {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  /* Media Container */
  .card-media {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    background-color: var(--border-light, #E5E5E5);
  }

  .media-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .work-highlight-card:hover .media-image {
    transform: scale(1.03);
  }

  .media-overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.1);
    color: #FFFFFF;
    transition: background 0.3s ease;
  }

  .work-highlight-card:hover .media-overlay {
    background: rgba(0, 0, 0, 0.2);
  }

  .play-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .work-highlight-card:hover .play-icon {
    transform: scale(1.1);
  }

  .duration-badge {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    background: rgba(0, 0, 0, 0.7);
    color: #FFF;
    font-family: var(--font-sans, sans-serif);
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  /* Content Container */
  .card-content {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    flex-grow: 1;
  }

  .content-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1rem;
  }

  .card-category {
    font-family: var(--font-sans, sans-serif);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent-slate, #666);
  }

  .card-duration {
    font-family: var(--font-sans, sans-serif);
    font-size: 0.75rem;
    color: var(--accent-slate, #666);
  }

  .card-title {
    font-family: var(--font-serif, serif);
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 1.2;
    color: var(--primary, #111);
    margin: 0 0 1rem 0;
  }

  .card-description {
    font-family: var(--font-sans, sans-serif);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--on-surface-variant, #444);
    margin: 0 0 1.5rem 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--border-light, #E5E5E5);
  }

  .card-cta {
    font-family: var(--font-sans, sans-serif);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--primary, #111);
    transition: color 0.3s ease;
  }

  .work-highlight-card:hover .card-cta {
    color: var(--accent-gold, #CBA052);
  }

  /* --- Size Modifiers for Grid Span --- */
  .size-large {
    grid-column: span 1;
  }

  @media (min-width: 768px) {
    .size-large {
      grid-column: span 2;
    }
    
    .size-large .card-title {
      font-size: 2rem;
    }
  }

  /* --- Style Modifiers --- */
  .style-text_card .card-content {
    background-color: #FFFFFF;
  }
  
  .style-text_card .card-media {
    display: none;
  }

  .style-release_card .card-media {
    aspect-ratio: 1/1; /* Square for album covers */
  }
</style>
